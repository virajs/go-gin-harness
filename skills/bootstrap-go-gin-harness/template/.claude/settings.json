{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],
  "skillListingBudgetFraction": 0.04,

  "permissions": {
    "allow": [
      "Read", "Glob", "Grep", "Edit", "Write", "MultiEdit",
      "WebSearch", "WebFetch",
      "Skill", "Agent", "Task", "TaskCreate", "TaskUpdate", "TaskList", "TaskGet",
      "Bash(go *)",
      "Bash(gofumpt *)",
      "Bash(goimports *)",
      "Bash(golangci-lint *)",
      "Bash(govulncheck *)",
      "Bash(gosec *)",
      "Bash(sqlc *)",
      "Bash(goose *)",
      "Bash(make *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git describe*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(chmod +x *)",
      "Bash(curl --help)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(docker logs*)",
      "Bash(docker inspect*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git add*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(git clean -f*)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(goose * down*)",
      "Bash(goose reset*)",
      "Bash(docker rm*)",
      "Bash(docker volume rm*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/protect-commands.sh"],
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-formatting.sh"],
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start-context.sh"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
