# EditorConfig — shared, cross-stack formatting baseline. Go formatting is owned by
# gofumpt + goimports; this file ensures editors agree on the basics regardless.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
insert_final_newline = true
trim_trailing_whitespace = true
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4

[*.{yaml,yml,json,toml,md}]
indent_style = space
indent_size = 2

[*.{sql,sh,ps1}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false   # markdown line breaks rely on trailing spaces
